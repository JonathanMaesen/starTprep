<%- include('./partials/head') %>
  <script type="module" src="scripts/foh.js" defer></script>

  <body class="foh">
    <%- include('./partials/nav') %>

      <main>
        <form action="/foh/sortfloor" method="post">
          <select name="sortOptions" id="">
            <label for="sortOptions">SortOptions</label>
            <option value="asc">asc</option>
            <option value="desc">desc</option>
            <option value="chairsAsc">chairs asc</option>
            <option value="chairsDesc">chairs desc</option>
          </select>
          <button type="submit">submit</button>
        </form>
        <form action="/foh/addtable" method="post">
